# Customer deployment environment for Tillforge Repository
# Copy to .env and set values.

# Image (keep latest by default)
REPO_IMAGE=ghcr.io/tillforge/tillforge-repository:latest

# Security (required)
REPO_ADMIN_API_KEY=replace-with-strong-admin-key
SYNC_API_SHARED_SECRET=replace-with-long-random-shared-secret

# Network binding
# Defaults are localhost-only. For VPC/server-to-server sync set both to 0.0.0.0
# and restrict access using firewall/security groups.
REPO_BIND_ADDRESS=127.0.0.1
REPO_PORT=8001
SYNC_BIND_ADDRESS=127.0.0.1
SYNC_API_PORT=9001

# SQLite default for most tenants
REPO_DB_BACKEND=sqlite
SYNC_DB_BACKEND=sqlite

# Optional PostgreSQL mode
# POSTGRES_DB=repository
# POSTGRES_USER=repo_user
# POSTGRES_PASSWORD=replace-with-strong-password
# REPO_DATABASE_URL=postgresql://repo_user:replace-with-strong-password@postgres:5432/repository
# SYNC_DB_NAME=pos_cmdb
# SYNC_DATABASE_URL=postgresql://repo_user:replace-with-strong-password@postgres:5432/pos_cmdb

# Automatic Let's Encrypt renewal
# CERTBOT_AUTO_RENEW=true
# CERTBOT_RENEW_INTERVAL_SECONDS=21600
# CERTBOT_RENEW_STARTUP_DELAY_SECONDS=120
# CERTBOT_AUTO_RESTART_ON_RENEW=true

# ClamAV sidecar integration (default for admin malware scan)
# CLAMAV_TCP_HOST=clamav
# CLAMAV_TCP_PORT=3310
# CLAMAV_SCAN_TARGET=/data/storage  # Optional override; auto-uses REPO_STORAGE_PATH when unset
# CLAMAV_SCAN_TIMEOUT_SECONDS=1800
# CLAMAV_QUARANTINE_ENABLED=true
# CLAMAV_QUARANTINE_DIR=/data/clamav/quarantine
